                  "price": "0.50",
                  "size": "15"
                }
              ],
              "asks": [
                {
                  "price": "0.52",
                  "size": "25"
                },
                {
                  "price": "0.53",
                  "size": "60"
                },
                {
                  "price": "0.54",
                  "size": "10"
                }
              ],
              "timestamp": "1757908892351",
              "hash": "0xabc123..."
            }
          }
        ]
      },
      "priceChange": {
        "name": "PriceChange",
        "title": "Price Change",
        "summary": "Orderbook price level delta update",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/PriceChangeEvent"
        },
        "examples": [
          {
            "name": "Price change",
            "payload": {
