      "marketResolved": {
        "name": "MarketResolved",
        "title": "Market Resolved",
        "summary": "Market resolution event — requires custom_feature_enabled: true",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/MarketResolvedEvent"
        },
        "examples": [
          {
            "name": "Market resolved",
