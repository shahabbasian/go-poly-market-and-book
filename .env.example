# ============================================
# Required: PostgreSQL connection string
# External PostgreSQL (already running in another Docker container)
# Example: postgres://user:password@postgres-host:5432/dbname?sslmode=disable
# ============================================
DATABASE_URL=postgres://user:password@your-postgres-host:5432/polymarket?sslmode=disable

# ============================================
# Optional: Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# Optional: API rate limiting (delay between requests in ms)
# ============================================
RATE_LIMIT_DELAY_MS=250

# ============================================
# Optional: Worker intervals (seconds)
# ============================================
DISCOVERY_INTERVAL_S=30
REFRESH_INTERVAL_S=60

# ============================================
# Optional: How many future slugs to generate per coin×interval combo
# ============================================
FUTURE_SLUG_COUNT=10
INITIAL_SLUG_COUNT=20

# ============================================
# Optional: CLOB batch settings
# ============================================
CLOB_BATCH_SIZE=50

# ============================================
# Optional: Refresh settings
# ============================================
REFRESH_MAX_AGE_M=5
REFRESH_LIMIT=100

# ============================================
# Optional: HTTP settings
# ============================================
HTTP_TIMEOUT_S=30
MAX_RETRIES=5

# ============================================
# Optional: Order book collector settings
# COLLECTOR_DELAY_MS: ms between batch requests (333 = 3 req/s)
# COLLECTOR_FLUSH_INTERVAL_S: flush buffer to DB every N seconds
# COLLECTOR_TOKEN_REFRESH_S: refresh token list from DB every N seconds
# COLLECTOR_BUFFER_MAX_ROWS: max rows before forced flush (safety limit)
# ============================================
COLLECTOR_DELAY_MS=333
COLLECTOR_FLUSH_INTERVAL_S=5
COLLECTOR_TOKEN_REFRESH_S=60
COLLECTOR_BUFFER_MAX_ROWS=1000
